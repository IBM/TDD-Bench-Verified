+def score_eval_results(eval_logs_path: str = "./eval_logs", output_path: str = "./scoring_results.json", dataset_path: Union[str, None] = None):
+    """
+    Read JSON files from eval logs and categorize instance IDs into three groups:
+    - Fail-to-pass: Tests that were failing before and passing after (resolved=True)
+    - Not Fail-to-pass: Tests that were not resolved (resolved=False or no improvement)
+    - Not found: Instance IDs that don't have result files
+    
+    Args:
+        eval_logs_path: Path to the directory containing eval log JSON files
+        output_path: Path to save the scoring results
+        dataset_path: Optional path to dataset file to get total sample count and identify missing instances
+        
+    Returns:
+        dict: Dictionary containing the three categories with instance IDs
+    """
+    from pathlib import Path
+    import json
+    
+    eval_logs_dir = Path(eval_logs_path)
+    
+    if not eval_logs_dir.exists():
+        raise ValueError(f"Eval logs directory not found: {eval_logs_path}")
+    
+    # Load dataset if provided to get total count and identify missing instances
+    all_instance_ids = set()
+    total_samples = 0
+    
+    if dataset_path:
+        try:
+            if dataset_path.endswith('.jsonl'):
+                # Read JSONL file
+                with open(dataset_path, 'r') as f:
+                    for line in f:
+                        data = json.loads(line.strip())
+                        if 'instance_id' in data:
+                            all_instance_ids.add(data['instance_id'])
+                total_samples = len(all_instance_ids)
+                logger.info(f"Loaded {total_samples} instance IDs from dataset: {dataset_path}")
+            elif dataset_path.endswith('.csv'):
+                # Read CSV file
+                dataset_df = pd.read_csv(dataset_path)
+                if 'instance_id' in dataset_df.columns:
+                    all_instance_ids = set(dataset_df['instance_id'].tolist())
+                    total_samples = len(all_instance_ids)
+                    logger.info(f"Loaded {total_samples} instance IDs from dataset: {dataset_path}")
+                else:
+                    logger.warning("'instance_id' column not found in CSV dataset")
+            else:
+                logger.warning(f"Unsupported dataset format: {dataset_path}. Expected .jsonl or .csv")
+        except Exception as e:
+            logger.error(f"Error loading dataset: {e}")
+    
+    # Initialize result categories
+    fail_to_pass = []
+    not_fail_to_pass = []
+    empty_file = []
+    
+    # Get all JSON result files
+    result_files = list(eval_logs_dir.glob("*_result.json"))
+    processed_instance_ids = set()
+    
+    logger.info(f"Found {len(result_files)} result files in {eval_logs_path}")
+    
+    for result_file in result_files:
+        # Extract instance_id from filename (e.g., google__gson-2337_result.json -> google__gson-2337)
+        instance_id = result_file.stem.replace("_result", "")
+        processed_instance_ids.add(instance_id)
+        
+        try:
+            with open(result_file, 'r') as f:
+                data = json.load(f)
+            
+            # Check if data is a list and has at least one element
+            if isinstance(data, list) and len(data) > 0:
+                result = data[0]
+                
+                # Check if resolved field exists and is True
+                if result.get("resolved", False):
+                    fail_to_pass.append(instance_id)
+                else:
+                    # Not resolved
+                    not_fail_to_pass.append(instance_id)
+            else:
+                # Empty or invalid data structure
+                logger.warning(f"Invalid data structure in {result_file}")
+                not_fail_to_pass.append(instance_id)
+                
+        except json.JSONDecodeError as e:
+            logger.error(f"Failed to parse JSON in {result_file}: {e}")
+            empty_file.append(instance_id)
+        except Exception as e:
+            logger.error(f"Error processing {result_file}: {e}")
+            empty_file.append(instance_id)
+    
+    # Identify missing instances if dataset was provided
+    missing_instances = []
+    if all_instance_ids:
+        missing_instances = sorted(list(all_instance_ids - processed_instance_ids))
+        logger.info(f"Missing instances (not in eval logs): {len(missing_instances)}")
+    
+    # Create summary
+    results = {
+        "fail_to_pass": {
+            "count": len(fail_to_pass),
+            "instance_ids": sorted(fail_to_pass)
+        },
+        "not_fail_to_pass": {
+            "count": len(not_fail_to_pass),
+            "instance_ids": sorted(not_fail_to_pass)
+        },
+        "empty_file": {
+            "count": len(empty_file),
+            "instance_ids": sorted(empty_file)
+        },
+        "missing": {
+            "count": len(missing_instances),
+            "instance_ids": missing_instances
+        },
+        "total_in_dataset": total_samples if total_samples > 0 else None,
+        "total_processed": len(result_files),
+        "summary": {
+            "fail_to_pass_rate": f"{len(fail_to_pass) / len(result_files) * 100:.2f}%" if result_files else "0.00%",
+            "not_fail_to_pass_rate": f"{len(not_fail_to_pass) / len(result_files) * 100:.2f}%" if result_files else "0.00%",
+            "empty_file_rate": f"{len(empty_file) / len(result_files) * 100:.2f}%" if result_files else "0.00%",
+            "missing_rate": f"{len(missing_instances) / total_samples * 100:.2f}%" if total_samples > 0 else "N/A",
+            "coverage_rate": f"{len(result_files) / total_samples * 100:.2f}%" if total_samples > 0 else "N/A"
+        }
+    }
+    
+    # Save results to file
+    output_file = Path(output_path)
+    with open(output_file, 'w') as f:
+        json.dump(results, f, indent=2)
+    
+    # Print summary
+    logger.info("=" * 60)
+    logger.info("SCORING RESULTS SUMMARY")
+    logger.info("=" * 60)
+    if total_samples > 0:
+        logger.info(f"Total samples in dataset: {total_samples}")
+        logger.info(f"Coverage: {results['summary']['coverage_rate']}")
+        logger.info("-" * 60)
+    logger.info(f"Total files processed: {results['total_processed']}")
+    logger.info(f"Fail-to-pass: {results['fail_to_pass']['count']} ({results['summary']['fail_to_pass_rate']})")
+    logger.info(f"Not Fail-to-pass: {results['not_fail_to_pass']['count']} ({results['summary']['not_fail_to_pass_rate']})")
+    logger.info(f"Empty file/Error: {results['empty_file']['count']} ({results['summary']['empty_file_rate']})")
+    if total_samples > 0:
+        logger.info(f"Missing from eval logs: {results['missing']['count']} ({results['summary']['missing_rate']})")
+    logger.info("=" * 60)
+    logger.info(f"Results saved to: {output_file}")
+    
+    return results
 
